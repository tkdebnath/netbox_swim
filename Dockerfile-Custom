FROM netboxcommunity/netbox:latest

# 1. Start as root for system tools and installation
USER root
RUN apt-get update && \
    apt-get install -y iputils-ping && \
    rm -rf /var/lib/apt/lists/*

# 2. Create the folder and set ownership
RUN mkdir -p /opt/netbox/netbox_swim && \
    chown -R netbox:root /opt/netbox/netbox_swim

# 3. Create a cached dependency layer
# By copying ONLY setup.py first, we cache the heavy installation
# of scrapli, netmiko, pyats, etc., and aren't subject to the cache-buster.
COPY setup.py /opt/netbox/netbox_swim/setup.py
RUN /usr/local/bin/uv pip install /opt/netbox/netbox_swim

# 4. Use the cache buster to force the plugin re-copy and re-install
ARG CACHEBUST=1

# 5. Copy the code while still as root
COPY . /opt/netbox/netbox_swim

# 6. INSTALL PLUGIN CODE AS ROOT 
# We use --no-deps so it avoids resolving or fetching remote packages again!
RUN /usr/local/bin/uv pip install --no-deps --upgrade --no-cache-dir /opt/netbox/netbox_swim

# 6. FIX PERMISSIONS
# Ensure everything in the venv and plugin folder is owned by netbox again
RUN chown -R netbox:root /opt/netbox/venv /opt/netbox/netbox_swim

# 8. Pre-create the swim log file with correct netbox ownership
RUN touch /opt/netbox/swim.log && \
    chown netbox:root /opt/netbox/swim.log && \
    chmod 664 /opt/netbox/swim.log

# 7. CRITICAL: Switch back to the 'netbox' user for security
USER netbox